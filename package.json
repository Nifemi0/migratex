{
  "name": "migratex",
  "version": "0.1.3",
  "description": "CLI migration engine skeleton for wagmi v1 → v2",
  "type": "commonjs",
  "main": "dist/src/cli/index.js",
  "bin": {
    "migratex": "dist/src/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node dist/src/cli/index.js",
    "start": "node dist/src/cli/index.js",
    "test": "vitest run",
    "lint": "echo \"no linter configured\"",
    "codemod:workflow:validate": "npx --yes codemod workflow validate -w workflow.yaml",
    "codemod:workflow:run": "npx --yes codemod workflow run -w workflow.yaml",
    "release:verify": "npm run build && npm test && npm run codemod:workflow:validate",
    "publish:staged": "node scripts/publish-staged.mjs"
  },
  "keywords": [
    "migrate",
    "codemod",
    "wagmi",
    "ts-morph"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nifemi0/migratex.git"
  },
  "homepage": "https://github.com/Nifemi0/migratex",
  "bugs": {
    "url": "https://github.com/Nifemi0/migratex/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "execa": "^7.1.1",
    "fast-glob": "^3.2.12",
    "ts-morph": "^17.0.1",
    "zod": "^3.22.2",
    "diff": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.6.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.2",
    "vitest": "^1.3.2"
  }
}
